{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Recordatorio",
  "version": "0.1.0",
  "identifier": "com.jodixsystem.recordatorio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Recordatorio",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 700,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../ritmo.wav",
      "target/release/libstdc++-6.dll",
      "target/release/WebView2Loader.dll"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/JDFO1999/Recordatorio/releases/latest/download/update.json"
      ],
      "pubkey": ""
    }
  }
}
